{
  "manifest_version": 3,
  "name": "My Health App",
  "version": "1.0.0",
  "description": "Quick access to patient data for healthcare staff",

  "action": {
    "default_popup": "index.html",
    "default_title": "Open Health App"
  },

  "permissions": [
    "activeTab",
    "storage"
  ],

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["index.html", "assets/*", "images/*"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}